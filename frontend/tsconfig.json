{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2023", "DOM"],
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "noEmit": false,
    "allowJs": true,
    "checkJs": false,
    "rootDir": "./src"
  },
  "include": ["src"]
}
